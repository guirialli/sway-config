
exec waybar
# Inicia o agente de autenticacao Polkit para janelas graficas de senha
exec /usr/bin/lxqt-policykit-agent &


#Applets
exec blueman-applet &
exec mako &
exec nm-applet --indicator &
exec $HOME/.config/waybar/scripts/toggle_idle.sh -s 
exec wl-paste --watch cliphist store

# Portals
exec --no-startup-id /usr/lib/xdg-desktop-portal-wlr & 
exec --no-startup-id /usr/lib/xdg-desktop-portal-gtk & 
exec --no-startup-id /usr/lib/xdg-desktop-portal &
exec --no-startup-id ~/.config/sway/scripts/monitor-swap.py -d & 

# Applications
exec ulauncher
exec autotiling


#Keyring
exec --no-startup-id gnome-keyring-daemon --start --components=gpg,pkcs11,secrets,ssh
exec --no-startup-id dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec systemctl --user start  polkit-gnome-authentication-agent-1.service


exec gammastep -l -13.85:-40.08 -t 6500:3500
