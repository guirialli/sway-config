# Torna a janela do agente Polkit do LXQt sempre flutuante e centralizada
for_window [app_id="lxqt-policykit-agent"] floating enable, resize set 600 400, move to center

for_window [app_id="org.pulseaudio.pavucontrol"] floating enable, resize set 1200 900, move to center

for_window [app_id="blueman-manager"] floating enable, resize set 800 600, move to center

for_window [app_id="ulauncher"] floating enable, move position center, border pixel  0
for_window [app_id="toggle_brightness_popup.py"] floating enable, move position center, resize set 500 10
for_window [app_id="org.gnome.Calculator"] floating enable, move position center, resize set 400 400

for_window [app_id="zapzap"] floating enable, move position center, resize set 1400 1000
for_window [app_id="vesktop"] floating enable, move position center, resize set 1400 1000

for_window [app_id="discord"] floating enable, move position center, resize set 1400 1000

for_window [class="steam"] floating enable, move position center
for_window [app_id="org.gnome.Calendar"] floating enable, move position center

for_window [title="Autenticação"] floating enable
for_window [title="Authentication"] floating enable
for_window [title="PolicyKit1 Authentication Agent"] floating enable
#Dev
for_window [app_id="glade-previewer"] floating enable, move position center
for_window [class="Emulator"] floating enable

for_window [title="ZapZap"] floating enable, resize set 1200 720, move position center


# System
for_window [title="SwayDisplaySwitcher"] floating enable, move position center, sticky enable, focus


for_window [app_id="sway.osd.volume"] floating enable
for_window [app_id="sway.osd.volume"] border none
for_window [app_id="sway.osd.volume"] sticky enable
for_window [app_id="sway.osd.volume"] move position center
